<odoo>

    <!-- Opens the Departments list when menu item is clicked -->
    <record id="action_hms_department" model="ir.actions.act_window">
        <field name="name">Departments</field>
        <field name="res_model">hms.department</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Table view -->
    <record id="view_hms_department_list" model="ir.ui.view">
        <field name="name">hms.department.list</field>
        <field name="model">hms.department</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="capacity"/>
                <field name="is_opened"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_hms_department_form" model="ir.ui.view">
        <field name="name">hms.department.form</field>
        <field name="model">hms.department</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="capacity"/>
                        <field name="is_opened"/>
                    </group>
                    <!-- Patients linked to this department -->
                    <notebook>
                        <page string="Patients">
                            <field name="patient_ids">
                                <list>
                                    <field name="first_name"/>
                                    <field name="last_name"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- "Departments" sub-menu under "Hospital" -->
    <menuitem id="menu_hms_department" name="Departments"
              parent="menu_hms_root" action="action_hms_department"/>

</odoo>
