<odoo>

    <!-- Opens the Patients list when menu item is clicked -->
    <record id="action_hms_patient" model="ir.actions.act_window">
        <field name="name">Patients</field>
        <field name="res_model">hms.patient</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Table view: columns shown in the patients list -->
    <record id="view_hms_patient_list" model="ir.ui.view">
        <field name="name">hms.patient.list</field>
        <field name="model">hms.patient</field>
        <field name="arch" type="xml">
            <list>
                <field name="first_name"/>
                <field name="last_name"/>
                <field name="birth_date"/>
                <field name="blood_type"/>
                <field name="state"/>
                <field name="department_id"/>
            </list>
        </field>
    </record>

    <!-- Form view: detail page for a single patient -->
    <record id="view_hms_patient_form" model="ir.ui.view">
        <field name="name">hms.patient.form</field>
        <field name="model">hms.patient</field>
        <field name="arch" type="xml">
            <form>
                <!-- State bar shown at the top -->
                <header>
                    <field name="state" widget="statusbar"
                           statusbar_visible="undetermined,good,fair,serious"/>
                </header>
                <sheet>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <group>
                        <!-- Left: personal info -->
                        <group>
                            <field name="first_name"/>
                            <field name="last_name"/>
                            <field name="birth_date"/>
                            <field name="age" readonly="1"/>
                            <field name="blood_type"/>
                        </group>
                        <!-- Right: medical + department info -->
                        <group>
                            <field name="email"/>
                            <field name="cr_ratio" required="pcr"/>
                            <field name="pcr"/>
                            <field name="address"/>
                            <!-- only open departments appear in the dropdown (domain is on the model) -->
                            <field name="department_id"/>
                            <!-- pulled from the selected department, cannot be edited -->
                            <field name="department_capacity"/>
                        </group>
                    </group>

                    <!-- Doctors: readonly until a department is chosen -->
                    <group string="Doctors">
                        <field name="doctor_ids" widget="many2many_tags"
                               nolabel="1" readonly="not department_id"/>
                    </group>

                    <!-- History tab: hidden when age is under 50 -->
                    <notebook invisible="age &lt; 50">
                        <page string="History">
                            <field name="history"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Top-level "Hospital" menu and "Patients" sub-menu -->
    <menuitem id="menu_hms_root" name="Hospital"/>
    <menuitem id="menu_hms_patient" name="Patients"
              parent="menu_hms_root" action="action_hms_patient"/>

</odoo>
