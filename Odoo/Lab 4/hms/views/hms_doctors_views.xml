<odoo>

    <!-- Opens the Doctors list when menu item is clicked -->
    <record id="action_hms_doctors" model="ir.actions.act_window">
        <field name="name">Doctors</field>
        <field name="res_model">hms.doctors</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Table view -->
    <record id="view_hms_doctors_list" model="ir.ui.view">
        <field name="name">hms.doctors.list</field>
        <field name="model">hms.doctors</field>
        <field name="arch" type="xml">
            <list>
                <field name="first_name"/>
                <field name="last_name"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_hms_doctors_form" model="ir.ui.view">
        <field name="name">hms.doctors.form</field>
        <field name="model">hms.doctors</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <group>
                        <field name="first_name"/>
                        <field name="last_name"/>
                    </group>
                    <!-- Patients assigned to this doctor -->
                    <notebook>
                        <page string="Patients">
                            <field name="patient_ids">
                                <list>
                                    <field name="first_name"/>
                                    <field name="last_name"/>
                                    <field name="blood_type"/>
                                    <field name="state"/>
                                    <field name="department_id"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- "Doctors" sub-menu under "Hospital" -->
    <menuitem id="menu_hms_doctors" name="Doctors"
              parent="menu_hms_root" action="action_hms_doctors"/>

</odoo>
