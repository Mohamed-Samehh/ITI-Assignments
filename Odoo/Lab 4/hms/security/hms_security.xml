<odoo>

    <!-- ============================================================= -->
    <!-- Application category shown in Settings > Users                -->
    <!-- ============================================================= -->
    <record id="module_category_hms" model="ir.module.category">
        <field name="name">Hospital Management</field>
        <field name="description">Access rights for the Hospital Management System</field>
        <field name="sequence">10</field>
    </record>

    <!-- ============================================================= -->
    <!-- User groups                                                   -->
    <!-- ============================================================= -->

    <!-- Plain user: manages only the patients he created -->
    <record id="group_hms_user" model="res.groups">
        <field name="name">User</field>
        <field name="category_id" ref="module_category_hms"/>
        <field name="comment">Can create/read/update his own patients, read departments and doctors.</field>
    </record>

    <!-- Manager: full control, automatically inherits everything a User can do -->
    <record id="group_hms_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="module_category_hms"/>
        <field name="implied_ids" eval="[(4, ref('group_hms_user'))]"/>
        <field name="comment">Full access to patients, departments and doctors.</field>
    </record>

    <!-- Give the administrator the Manager role out of the box -->
    <record id="base.user_admin" model="res.users">
        <field name="groups_id" eval="[(4, ref('group_hms_manager'))]"/>
    </record>

    <!-- ============================================================= -->
    <!-- Record rules on hms.patient                                   -->
    <!--                                                               -->
    <!-- Group rules are OR-ed together for a user who belongs to      -->
    <!-- several groups. Since a Manager also belongs to User (via     -->
    <!-- implied_ids), "own records" OR "all records" => all records.  -->
    <!-- ============================================================= -->

    <!-- User: only the patients he created -->
    <record id="rule_hms_patient_user_own" model="ir.rule">
        <field name="name">Patient: User can access only his own records</field>
        <field name="model_id" ref="model_hms_patient"/>
        <field name="groups" eval="[(4, ref('group_hms_user'))]"/>
        <field name="domain_force">[('create_uid', '=', user.id)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- Manager: every patient record -->
    <record id="rule_hms_patient_manager_all" model="ir.rule">
        <field name="name">Patient: Manager can access all records</field>
        <field name="model_id" ref="model_hms_patient"/>
        <field name="groups" eval="[(4, ref('group_hms_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

</odoo>
